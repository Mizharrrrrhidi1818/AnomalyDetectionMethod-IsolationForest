        "# =============================================================================\n",
        "# Note: The UCI Credit Card dataset is provided as a single Excel sheet.\n",
        "# We load it as one unified dataset for robust validation.\n",
        "df = pd.read_excel('default of credit card clients.xls', header=1)\n",
        "print(f\"✅ Dataset loaded. Shape: {df.shape}\")\n",
        "\n",
        "# =============================================================================\n",
        "# 1. DATA EXPLORATION & PREPROCESSING\n",
        "# =============================================================================\n",
        "# 1a. Statistical Description\n",
        "print(\"\\n📊 1a. Statistical Description:\")\n",
